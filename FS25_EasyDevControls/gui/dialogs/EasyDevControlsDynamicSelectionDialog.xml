<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBgElement"/>

    <GuiElement profile="edc_dynamicSelectionDialogBg" id="dialogElement">
        <ThreePartBitmap profile="fs25_dialogBgTopSmall" position="6px 0px"/>
        <ThreePartBitmap profile="fs25_dialogBgMiddleSmall" position="6px 90px"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom" position="6px 0px"/>

        <Bitmap profile="edc_dynamicSelectionDialogHeaderBox">
            <Text profile="edc_dynamicSelectionDialogHeaderText" text="" id="dialogHeaderElement"/>
        </Bitmap>

        <BoxLayout profile="edc_dynamicSelectionDialogLayout" id="propertiesLayoutElement">
            <MultiTextOption profile="edc_dynamicSelectionMultiTextOption" id="multiTextOptionTemplate">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="title" text="Title"/>
            </MultiTextOption>

            <BinaryOption profile="edc_dynamicSelectionBinaryOption" id="binaryOptionTemplate">
                <Text profile="edc_title" name="title" text="Title"/>
            </BinaryOption>

            <EasyDevControlsTextInput profile="edc_dynamicSelectionTextInput" id="textInputTemplate">
                <ThreePartBitmap profile="edc_outlineBg"/>
                <ThreePartBitmap profile="edc_textInputIconBox">
                    <Bitmap profile="edc_textInputIcon"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="title" text="Title"/>
            </EasyDevControlsTextInput>

            <Button profile="edc_dynamicSelectionButton" id="buttonTemplate">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="title" text="Title"/>
            </Button>

            <GuiElement profile="edc_dynamicSelectionSpacer" id="spacerTemplate"/>
        </BoxLayout>

        <BoxLayout profile="fs25_dialogButtonBox" position="6px 32px">
            <Button profile="buttonActivate" text="$l10n_button_apply" onClick="onConfirm" id="applyButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator" id="applyButtonBoxSeparator"/>
            <Button profile="buttonOK" text="$l10n_button_confirm" onClick="onConfirm" id="confirmButton"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator" id="confirmButtonBoxSeparator"/>
            <Button profile="buttonBack" text="$l10n_button_back" onClick="onConfirm" id="backButton"/>
        </BoxLayout>
    </GuiElement>

    <GUIProfiles>
        <Profile name="edc_dynamicSelectionDialogBg" extends="baseReference" with="edc_pivotMiddleCenter">
            <size value="384px 178px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionDialogBgBottom" extends="baseReference" with="edc_pivotBottomCenter">
            <size value="384px 178px"/>
            <position value="0px 16px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionDialogBgRight" extends="baseReference" with="edc_pivotMiddleRight">
            <size value="384px 178px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionDialogHeaderBox" extends="baseReference" with="edc_anchorTopStretchingX">
            <size value="90% 60px"/>
            <position value="6px 60px"/>
            <imageColor value="$preset_edc_colourTransparent"/>
        </Profile>

        <Profile name="edc_dynamicSelectionDialogHeaderText" extends="edc_textDefault" with="edc_anchorStretchingYStretchingX edc_pivotMiddleLeft">
            <size value="100% 30px"/>
            <textSize value="28px"/>
            <textOffset value="0 0"/>
            <textUpperCase value="true"/>
            <textLayoutMode value="scrolling"/>
            <textScrollOnFocusOnly value="false"/>
        </Profile>

        <Profile name="edc_dynamicSelectionDialogLayout" extends="baseReference" with="edc_anchorStretchingYStretchingX edc_pivotTopLeft">
            <size value="360px 84px"/>
            <position value="12px -20px"/>
            <imageColor value="$preset_edc_colourTransparent"/>
            <flowDirection value="horizontal"/>
            <fitFlowToElements value="true"/>
            <numFlows value="0"/>
            <wrapAround value="true"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
        </Profile>

        <Profile name="edc_dynamicSelectionDialogLayoutVertical" extends="edc_dynamicSelectionDialogLayout">
            <flowDirection value="vertical"/>
        </Profile>

        <Profile name="edc_dynamicSelectionMultiTextOption" extends="edc_multiTextOption">
            <margin value="22px 24px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionMultiTextOptionClose" extends="edc_multiTextOption">
            <margin value="22px -18px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionMultiTextOptionLimited" extends="edc_dynamicSelectionMultiTextOption">
            <hideButtonOnLimitReached value="true"/>
            <wrap value="false"/>
        </Profile>

        <Profile name="edc_dynamicSelectionMultiTextOptionLimitedClose" extends="edc_dynamicSelectionMultiTextOptionLimited">
            <margin value="22px -18px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionBinaryOption" extends="edc_binaryOption">
            <margin value="22px 24px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionBinaryOptionClose" extends="edc_binaryOption">
            <margin value="22px -18px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionTextInput" extends="edc_textInput">
            <margin value="22px 24px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionTextInputClose" extends="edc_dynamicSelectionTextInput">
            <margin value="22px -18px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionButton" extends="edc_button">
            <margin value="22px 24px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionButtonClose" extends="edc_button">
            <margin value="22px -18px 22px 24px"/>
        </Profile>

        <Profile name="edc_dynamicSelectionSpacer" extends="emptyPanel" with="edc_anchorMiddleRight">
            <size value="316px 36px"/>
            <position value="0px 0px"/>
            <margin value="22px 24px 22px 24px"/>
            <debugEnabled value="false"/>
        </Profile>
    </GUIProfiles>
</GUI>
