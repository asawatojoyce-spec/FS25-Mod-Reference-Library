<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="easyDevControlsVehicles">
    <GuiElement profile="edc_container">
        <GuiElement profile="edc_headerPanel">
            <Bitmap profile="edc_headerIconBg">
                <Bitmap profile="edc_headerIcon" id="categoryHeaderIcon" imageSliceId="easyDevControls.icon_vehicles"/>
            </Bitmap>

            <Text profile="edc_headerTitle" id="categoryHeaderText" text="$l10n_easyDevControls_vehiclesHeader"/>
            <Button profile="edc_headerInfoButton" id="buttonShowInfo" onClick="onClickShowInfo"/>
        </GuiElement>

        <BoxLayout profile="edc_boxLayout" id="boxLayout">
            <!-- Column 1 -->
            <ThreePartBitmap profile="edc_outlineBg" size="316px 36px" margin="44px 22px 44px 24px">
                <Text profile="edc_title" id="titleVehicleSelection" text="$l10n_ui_statisticViewVehicleSelection"/>
                <Text profile="edc_placeholderText" id="textVehicleSelection" text="N/A" textScrollOnFocusOnly="false"/>
            </ThreePartBitmap>
            <Button profile="edc_buttonNoIconClose" id="buttonNextVehicle" onClick="onClickNextVehicle" text="$l10n_ui_next">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <MultiTextOption profile="edc_multiTextOptionLimited" id="multiResetState">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_reloadVehicleTitle"/>
            </MultiTextOption>
            <Button profile="edc_buttonClose" id="buttonConfirmReload" onClick="onClickConfirmReload">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <Button profile="edc_button" id="buttonConfirmAnalyseVehicle" onClick="onClickConfirmAnalyseVehicle">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_analyseVehicleTitle"/>
            </Button>

            <MultiTextOption profile="edc_multiTextOption" id="multiFillUnit" onClick="onClickFillUnit">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" id="textFillUnitFillLevelTitle" text="$l10n_easyDevControls_fillUnitFillLevelTitle"/>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiFillType" onClick="onClickFillType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiFillChange" onClick="onClickFillState">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <EasyDevControlsTextInput profile="edc_textInputClose" id="textInputFillAmount" placeholderVisibleOnDisable="true" onEnterPressed="onFillAmountEnterPressed" onEscPressed="onTextInputEscPressed" onTextChanged="onTextInputTextChanged" enterWhenClickOutside="true"  maxCharacters="7">
                <ThreePartBitmap profile="edc_outlineBg"/>
                <ThreePartBitmap profile="edc_textInputIconBox">
                    <Bitmap profile="edc_textInputIcon"/>
                </ThreePartBitmap>
            </EasyDevControlsTextInput>
            <Button profile="edc_buttonClose" id="buttonConfirmFillLevel" onClick="onClickConfirmFillLevel" margin="44px -18px 44px 98px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <!-- Column 2 -->
            <Button profile="edc_button" id="buttonToggleCover" onClick="onClickToggleCover">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_toggleCoverTitle"/>
            </Button>

            <MultiTextOption profile="edc_multiTextOption" id="multiConditionType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vehicleConditionTitle"/>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiConditionSetAddRemove" onClick="onClickConditionSetAddRemove">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <OptionSlider profile="edc_optionSliderClose" id="optionSliderConditionPercent">
                <ThreePartBitmap profile="edc_optionSliderBg" name="ignore">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </OptionSlider>
            <Button profile="edc_buttonClose" id="buttonConfirmCondition" onClick="onClickConfirmCondition">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <MultiTextOption profile="edc_multiTextOption" id="multiFuelChange" onClick="onClickFuelChangeType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vehicleFuelTitle"/>
            </MultiTextOption>
            <EasyDevControlsTextInput profile="edc_textInputClose" id="textInputFuel" placeholderVisibleOnDisable="true" onEnterPressed="onFuelEnterPressed" onEscPressed="onTextInputEscPressed" onTextChanged="onTextInputTextChanged" enterWhenClickOutside="false"  maxCharacters="7">
                <ThreePartBitmap profile="edc_outlineBg"/>
                <ThreePartBitmap profile="edc_textInputIconBox">
                    <Bitmap profile="edc_textInputIcon"/>
                </ThreePartBitmap>
            </EasyDevControlsTextInput>
            <Button profile="edc_buttonClose" id="buttonConfirmFuel" onClick="onClickConfirmFuel" margin="44px -18px 44px 222px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <!-- Column 3 -->
            <Button profile="edc_button" id="buttonSetPowerConsumer" onClick="onClickSetPowerConsumer">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_setPowerConsumerTitle"/>
            </Button>

            <EasyDevControlsTextInput profile="edc_textInput" id="textInputMotorTemp" placeholderVisibleOnDisable="true" placeholderDefaultText="Current: 0°C" onEnterPressed="onMotorTempEnterPressed" onEscPressed="onTextInputEscPressed" onTextChanged="onTextInputTextChanged" enterWhenClickOutside="false"  maxCharacters="3">
                <ThreePartBitmap profile="edc_outlineBg"/>
                <ThreePartBitmap profile="edc_textInputIconBox">
                    <Bitmap profile="edc_textInputIcon"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vehicleMotorTempTitle"/>
            </EasyDevControlsTextInput>

            <EasyDevControlsTextInput profile="edc_textInput" id="textInputOperatingTime" placeholderVisibleOnDisable="true" placeholderDefaultText="Current: 0.00 h" onEnterPressed="onOperatingTimeEnterPressed" onEscPressed="onTextInputEscPressed" onTextChanged="onOperatingTimeTextChanged" enterWhenClickOutside="false"  maxCharacters="5">
                <ThreePartBitmap profile="edc_outlineBg"/>
                <ThreePartBitmap profile="edc_textInputIconBox">
                    <Bitmap profile="edc_textInputIcon"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vehicleOperatingTimeTitle"/>
            </EasyDevControlsTextInput>

            <Button profile="edc_button" id="buttonConfirmRemoveAllVehicles" onClick="onClickConfirmRemoveAllVehicles" margin="44px 24px 44px 348px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_removeAllVehiclesTitle"/>
            </Button>

            <!-- Column 4 -->
            <MultiTextOption profile="edc_multiTextOptionLimited" id="multiGlobalWiperState" onClick="onClickGlobalWiperState">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_globalWiperStateTitle"/>
            </MultiTextOption>

            <BinaryOption profile="edc_binaryOption" id="binaryShowVehicleDistance" onClick="onClickShowVehicleDistance">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vehicleDistanceTitle"/>
            </BinaryOption>

            <MultiTextOption profile="edc_multiTextOption" id="multiVehicleDebug" onClick="onClickVehicleDebug">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vehicleDebugTitle"/>
            </MultiTextOption>

            <BinaryOption profile="edc_binaryOption" id="binaryTensionBeltsDebug" onClick="onClickTensionBeltsDebug">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_tensionBeltsDebugTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" id="binaryWetnessDebug" onClick="onClickWetnessDebug">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_wetnessDebugTitle"/>
            </BinaryOption>
        </BoxLayout>

        <ThreePartBitmap profile="edc_infoBoxBg">
            <Bitmap profile="edc_infoBoxIconBox">
                <Bitmap profile="edc_infoBoxIcon" id="infoBoxIcon"/>
            </Bitmap>
            <Text profile="edc_infoBoxText" id="infoBoxText"/>
        </ThreePartBitmap>
    </GuiElement>
</GUI>
