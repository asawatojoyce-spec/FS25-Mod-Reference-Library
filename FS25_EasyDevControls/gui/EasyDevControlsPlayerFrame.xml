<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="easyDevControlsPlayer">
    <GuiElement profile="edc_container">
        <GuiElement profile="edc_headerPanel">
            <Bitmap profile="edc_headerIconBg">
                <Bitmap profile="edc_headerIcon" id="categoryHeaderIcon" imageSliceId="easyDevControls.icon_player"/>
            </Bitmap>

            <Text profile="edc_headerTitle" id="categoryHeaderText" text="$l10n_easyDevControls_playerHeader"/>
            <Button profile="edc_headerInfoButton" id="buttonShowInfo" onClick="onClickShowInfo"/>
        </GuiElement>

        <BoxLayout profile="edc_boxLayout" id="boxLayout">
            <!-- Column 1 -->
            <BinaryOption profile="edc_binaryOption" id="binarySuperStrength" onClick="onClickSuperStrength">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_superStrengthTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" id="binarySuperStrengthKey" onClick="onClickSuperStrengthKey">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_superStrengthKeyTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" id="binaryFlightModeToggle" onClick="onClickFlightMode">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_flightModeToggleTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" id="binaryFlightModeState" onClick="onClickFlightMode" margin="44px 24px 44px 356px" debugMargin="true">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_flightModeStateTitle"/>
            </BinaryOption>

            <!-- Column 2 -->
            <MultiTextOption profile="edc_multiTextOption" id="multiJumpDelay" onClick="onClickJumpDelay" texts="$l10n_ui_none" hideButtonOnLimitReached="true" wrap="false">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_jumpDelayTitle"/>
            </MultiTextOption>

            <MultiTextOption profile="edc_multiTextOption" id="multiJumpMultiplier" onClick="onClickJumpMultiplier" texts="$l10n_ui_off" hideButtonOnLimitReached="true" wrap="false">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_jumpMultiplierTitle"/>
            </MultiTextOption>

            <MultiTextOption profile="edc_multiTextOption" id="multiRunSpeedMultiplier" onClick="onClickRunSpeed" texts="1x" hideButtonOnLimitReached="true" wrap="false">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_runSpeedTitle"/>
            </MultiTextOption>
            <BinaryOption profile="edc_binaryOptionClose" id="binaryRunSpeedState" onClick="onClickRunSpeedState"/>

            <BinaryOption profile="edc_binaryOption" id="binaryRunSpeedKey" onClick="onClickRunSpeedKey" margin="44px 24px 44px 310px" debugMargin="true">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_runSpeedKeyTitle"/>
            </BinaryOption>

            <!-- Column 3 -->
            <BinaryOption profile="edc_binaryOption" id="binaryNoClip" onClick="onClickNoClip">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_noClipTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" id="binaryWoodCuttingMarker" onClick="onClickWoodCuttingMarker">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_woodCuttingMarkerTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" id="binaryAimOverlay" onClick="onClickAimOverlay">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_aimOverlayTitle"/>
            </BinaryOption>

            <MultiTextOption profile="edc_multiTextOption" id="multiSetFarmObject" texts="$l10n_ui_playerCharacter" hideButtonOnLimitReached="true" wrap="false">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_setFarmTitle"/>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiSetFarm" texts="$l10n_defaultFarmName" hideButtonOnLimitReached="true" wrap="false">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <Button profile="edc_buttonClose" id="buttonConfirmSetFarm" onClick="onClickConfirmSetFarm" margin="44px -18px 44px 270px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <!-- Column 4 -->
            <BinaryOption profile="edc_binaryOption" name="INITIALISATION" id="binaryDebugDisplay[1]" onClick="onClickPlayerDebugDisplay">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_playerDebugInitialisationTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" name="HANDTOOLS" id="binaryDebugDisplay[2]" onClick="onClickPlayerDebugDisplay">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_playerDebugHandToolsTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" name="NETWORK" id="binaryDebugDisplay[3]" onClick="onClickPlayerDebugDisplay">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_playerDebugNetworkTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" name="GRAPHICS" id="binaryDebugDisplay[4]" onClick="onClickPlayerDebugDisplay">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_playerDebugGraphicsTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" name="STATE" id="binaryDebugDisplay[5]" onClick="onClickPlayerDebugDisplay">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_playerDebugStateTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" name="MOVEMENT" id="binaryDebugDisplay[6]" onClick="onClickPlayerDebugDisplay">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_playerDebugMovementTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" name="INPUT" id="binaryDebugDisplay[7]" onClick="onClickPlayerDebugDisplay">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_playerDebugInputTitle"/>
            </BinaryOption>
        </BoxLayout>

        <ThreePartBitmap profile="edc_infoBoxBg">
            <Bitmap profile="edc_infoBoxIconBox">
                <Bitmap profile="edc_infoBoxIcon" id="infoBoxIcon"/>
            </Bitmap>
            <Text profile="edc_infoBoxText" id="infoBoxText"/>
        </ThreePartBitmap>
    </GuiElement>
</GUI>
