<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="easyDevControlsFarmlands">
    <GuiElement profile="edc_container" debugEnabled="false">
        <GuiElement profile="edc_headerPanel">
            <Bitmap profile="edc_headerIconBg">
                <Bitmap profile="edc_headerIcon" id="categoryHeaderIcon" imageSliceId="easyDevControls.icon_farmlands"/>
            </Bitmap>

            <Text profile="edc_headerTitle" id="categoryHeaderText" text="$l10n_easyDevControls_fieldsHeader"/>
            <Button profile="edc_headerInfoButton" id="buttonShowInfo" onClick="onClickShowInfo"/>
        </GuiElement>

        <BoxLayout profile="edc_boxLayout" id="boxLayout" debugEnabled="false">
            <!-- Column 1 -->
            <Button profile="edc_button" name="setFruit" id="buttonFieldSetFruit" onClick="onClickFieldSet">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_fieldSetFruitTitle"/>
            </Button>

            <Button profile="edc_button" name="setGround" id="buttonFieldSetGround" onClick="onClickFieldSet">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_fieldSetGroundTitle"/>
            </Button>

            <Button profile="edc_button" id="buttonRiceFieldSet" onClick="onClickRiceFieldSet" >
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_setRiceFieldTitle"/>
            </Button>

            <MultiTextOption profile="edc_multiTextOption" id="multiVineSetStateFruitType" onClick="onClickVineSetStateFruitType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vineSetStateTitle"/>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiVineSetStateGrowthState">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <Button profile="edc_buttonClose" id="buttonConfirmVineSetState" onClick="onClickConfirmVineSetState">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
            </Button>

            <Button profile="edc_button" id="buttonVineUpdateVisuals" onClick="onClickVineUpdateVisuals" margin="44px 24px 44px 190px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vineUpdateVisualsTitle"/>
            </Button>

            <!-- Column 2 -->
            <ThreePartBitmap profile="edc_outlineBg" size="316px 36px" margin="44px 22px 44px 24px">
                <Text profile="edc_title" text="$l10n_setting_weedsEnabled"/>
                <Text profile="edc_placeholderText" id="textDisplayWeeds" text="$l10n_easyDevControls_noField"/>
            </ThreePartBitmap>
            <Button profile="edc_buttonAddRemoveLeft" name="removeWeeds" id="buttonRemoveWeeds" onClick="onClickRemove">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
            </Button>
            <Button profile="edc_buttonAddRemoveRight" name="addWeeds" id="buttonAddWeeds" onClick="onClickAdd">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
            </Button>

            <ThreePartBitmap profile="edc_outlineBg" size="316px 36px" margin="44px 22px 44px 24px">
                <Text profile="edc_title" text="$l10n_setting_stonesEnabled"/>
                <Text profile="edc_placeholderText" id="textDisplayStones" text="$l10n_easyDevControls_noField"/>
            </ThreePartBitmap>
            <Button profile="edc_buttonAddRemoveLeft" name="removeStones" id="buttonRemoveStones" onClick="onClickRemove">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
            </Button>
            <Button profile="edc_buttonAddRemoveRight" name="addStones" id="buttonAddStones" onClick="onClickAdd">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
            </Button>

            <Button profile="edc_button" id="buttonConfirmAdvanceGrowth" onClick="onClickConfirmAdvanceGrowth">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_advanceGrowthTitle"/>
            </Button>

            <MultiOption profile="edc_multiTextOption" id="multiGrowthPeriod" texts="$l10n_ui_month1|$l10n_ui_month2|$l10n_ui_month3|$l10n_ui_month4|$l10n_ui_month5|$l10n_ui_month6|$l10n_ui_month7|$l10n_ui_month8|$l10n_ui_month9|$l10n_ui_month10|$l10n_ui_month11|$l10n_ui_month12">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_setGrowthPeriodTitle"/>
            </MultiOption>
            <Button profile="edc_buttonClose" id="buttonConfirmGrowthPeriod" onClick="onClickConfirmGrowthPeriod" margin="44px -18px 44px 234px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
            </Button>

            <!-- Column 3 -->
            <MultiTextOption profile="edc_multiTextOption" id="multiSetFarmlandOwnerIndex" onClick="onClickSetFarmlandOwnerIndex">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_setFarmlandOwnerTitle"/>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiSetFarmlandFarmId" onClick="onClickSetFarmlandFarmId">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <Button profile="edc_buttonClose" id="buttonConfirmSetFarmlandOwner" onClick="onClickConfrimSetFarmlandOwner">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
            </Button>

            <ThreePartBitmap profile="edc_outlineBg" size="316px 36px" margin="44px 22px 44px 24px">
                <Text profile="edc_title" text="$l10n_easyDevControls_refreshFieldOverlayTitle"/>
                <Text profile="edc_placeholderText" id="textRefreshFieldOverlay"/>
            </ThreePartBitmap>
            <Button profile="edc_buttonRefresh" text="$l10n_button_refresh" id="buttonRefreshFieldOverlay" onClick="onClickRefreshFieldOverlay" margin="44px -18px 44px 400px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_buttonOutline"/>
            </Button>

            <!-- Column 4 -->
            <BinaryOption profile="edc_binaryOption" id="binaryDebugFieldStatus" onClick="onClickDebugFieldStatus">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_debugFieldStatusTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" id="binaryDebugVineSystem" onClick="onClickDebugVineSystem">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_vineSystemDebugTitle"/>
            </BinaryOption>

            <BinaryOption profile="edc_binaryOption" id="binaryDebugStoneSystem" onClick="onClickDebugStoneSystem">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_stoneSystemDebugTitle"/>
            </BinaryOption>
        </BoxLayout>

        <ThreePartBitmap profile="edc_infoBoxBg">
            <Bitmap profile="edc_infoBoxIconBox">
                <Bitmap profile="edc_infoBoxIcon" id="infoBoxIcon"/>
            </Bitmap>
            <Text profile="edc_infoBoxText" id="infoBoxText"/>
        </ThreePartBitmap>
    </GuiElement>
</GUI>
