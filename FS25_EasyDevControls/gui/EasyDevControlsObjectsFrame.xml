<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="easyDevControlsObjects">
    <GuiElement profile="edc_container" debugEnabled="false">
        <GuiElement profile="edc_headerPanel">
            <Bitmap profile="edc_headerIconBg">
                <Bitmap profile="edc_headerIcon" id="categoryHeaderIcon" imageSliceId="easyDevControls.icon_objects"/>
            </Bitmap>

            <Text profile="edc_headerTitle" id="categoryHeaderText" text="$l10n_easyDevControls_objectsHeader"/>
            <Button profile="edc_headerInfoButton" id="buttonShowInfo" onClick="onClickShowInfo"/>
        </GuiElement>

        <BoxLayout profile="edc_boxLayout" id="boxLayout" debugEnabled="false">
            <!-- Column 1 -->
            <MultiTextOption profile="edc_multiTextOption" id="multiBaleType" onClick="onClickBaleType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_addBaleTitle"/>
            </MultiTextOption>
            <OptionSlider profile="edc_optionSliderClose" id="optionSliderBaleSize" onClick="onClickBaleSize">
                <ThreePartBitmap profile="edc_optionSliderBg" name="ignore">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </OptionSlider>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiBaleFillType" onClick="onClickBaleFillType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiBaleWrapState" onClick="onClickBaleWrapState">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <Button profile="edc_colourButtonClose" id="buttonBaleWrapColour" onClick="onClickSelectColour">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <Bitmap profile="edc_colourButtonPicked" id="bitmapBaleWrapColour"/>
                <ThreePartBitmap profile="edc_outlineBg">
                    <ThreePartBitmap profile="edc_textInputIconBox">
                        <Bitmap profile="edc_colourButtonIcon"/>
                    </ThreePartBitmap>
                </ThreePartBitmap>
            </Button>
            <Button profile="edc_buttonClose" id="buttonConfirmBale" onClick="onClickConfirmBale">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <Button profile="edc_button" onClick="onClickShowBaleList">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_availableBaleTypesTitle"/>
            </Button>

            <Button profile="edc_button" onClick="onClickShowBalesFermenting">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_fermentingBalesTitle"/>
            </Button>

            <ThreePartBitmap profile="edc_outlineBg" size="316px 36px" margin="44px 22px 44px 24px"> <!-- TO_DO: Replace with info button -->
                <Text profile="edc_title" name="ignore" text="$l10n_category_bales"/>
                <Text profile="edc_placeholderText" id="textBaleCount" text="0 / 0"/>
            </ThreePartBitmap>

            <Button profile="edc_button" name="BALE" id="buttonConfirmRemoveAllBales" onClick="onClickConfirmRemoveAll" margin="44px 22px 44px 64px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_removeAllBalesTitle"/>
            </Button>

            <!-- Column 2 -->
            <MultiTextOption profile="edc_multiTextOption" id="multiPalletCategory" onClick="onClickPalletCategory">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_addPalletTitle"/>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiPalletFillType" onClick="onClickPalletFillType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiPalletAmount" onClick="onClickPalletAmount">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <EasyDevControlsTextInput profile="edc_textInputClose" id="textInputPalletAmount" placeholderVisibleOnDisable="true" placeholderDefaultText="$l10n_easyDevControls_maximum" onEnterPressed="onEnterPressedPalletAmount" onEscPressed="onTextInputEscPressed" onTextChanged="onTextInputTextChanged" enterWhenClickOutside="false">
                <ThreePartBitmap profile="edc_outlineBg"/>
                <ThreePartBitmap profile="edc_textInputIconBox">
                    <Bitmap profile="edc_textInputIcon"/>
                </ThreePartBitmap>
            </EasyDevControlsTextInput>
            <Button profile="edc_buttonClose" id="buttonConfirmPallet" onClick="onClickConfirmPallet">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <ThreePartBitmap profile="edc_outlineBg" size="316px 36px" margin="44px 22px 44px 24px"> <!-- TO_DO: Replace with info button -->
                <Text profile="edc_title" name="ignore" text="$l10n_category_pallets"/>
                <Text profile="edc_placeholderText" id="textPalletCount" text="0 / 0"/>
            </ThreePartBitmap>

            <Button profile="edc_button" name="PALLET" id="buttonConfirmRemoveAllPallets" onClick="onClickConfirmRemoveAll" margin="44px 22px 44px 274px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_removeAllPalletsTitle"/>
            </Button>

            <!-- Column 3 -->
            <MultiTextOption profile="edc_multiTextOption" id="multiLogType" onClick="onClickLogType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_addLogTitle"/>
            </MultiTextOption>
            <OptionSlider profile="edc_optionSliderClose" id="optionSliderLogLength" onClick="onClickLogLength">
                <ThreePartBitmap profile="edc_optionSliderBg" name="ignore">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </OptionSlider>
            <Button profile="edc_buttonClose" id="buttonConfirmLog" onClick="onClickConfirmLog">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <MultiOption profile="edc_multiTextOption" id="multiTreeType" onClick="onClickTreeType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_plantTreeTitle"/>
            </MultiOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiTreeGrowthState" onClick="onClickTreeGrowthState">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiTreeVariation" onClick="onClickTreeVariation">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiTreeIsGrowing" onClick="onClickTreeIsGrowing" texts="$l10n_easyDevControls_growing|$l10n_easyDevControls_decoration">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <Button profile="edc_buttonClose" id="buttonConfirmPlantTree" onClick="onClickConfirmPlantTree">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <ThreePartBitmap profile="edc_outlineBg" size="316px 36px" margin="44px 22px 44px 24px"> <!-- TO_DO: Replace with info button -->
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_splitShapesTitle"/>
                <Text profile="edc_placeholderText" id="textTreeCount" text="0 / 0"/>
            </ThreePartBitmap>

            <MultiTextOption profile="edc_multiTextOption" id="multiRemoveSplitShapesTypes" onClick="onClickRemoveSplitShapesTypes">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_removeAllSplitShapesTitle"/>
            </MultiTextOption>
            <Button profile="edc_buttonClose" id="buttonConfirmRemoveSplitShapes" onClick="onClickConfirmRemoveSplitShapes" margin="44px -18px 44px 58px" debugMargin="true">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <!-- Column 4 -->
            <MultiTextOption profile="edc_multiTextOption" id="multiTipAnywhereFillType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_tipToGroundTitle"/>
            </MultiTextOption>
            <OptionSlider profile="edc_optionSliderClose" id="optionSliderTipAnywhereLength">
                <ThreePartBitmap profile="edc_optionSliderBg" name="ignore">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </OptionSlider>
            <EasyDevControlsTextInput profile="edc_textInputClose" id="textInputTipAnywhereAmount" onEnterPressed="onTipAnywhereAmountEnterPressed" onEscPressed="onTextInputEscPressed" onTextChanged="onTextInputTextChanged" enterWhenClickOutside="true">
                <ThreePartBitmap profile="edc_outlineBg"/>
                <ThreePartBitmap profile="edc_textInputIconBox">
                    <Bitmap profile="edc_textInputIcon"/>
                </ThreePartBitmap>
            </EasyDevControlsTextInput>
            <Button profile="edc_buttonClose" id="buttonConfirmTipAnywhere" onClick="onClickConfirmTipAnywhere">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <MultiTextOption profile="edc_multiTextOption" id="multiClearTipAnywhereFillType">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_clearTipAreaTitle"/>
            </MultiTextOption>
            <MultiTextOption profile="edc_multiTextOptionClose" id="multiClearTipAnywhereState" onClick="onClickClearTipAnywhereState">
                <ThreePartBitmap profile="edc_multiTextOptionBg" name="background">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </MultiTextOption>
            <OptionSlider profile="edc_optionSliderClose" id="optionSliderClearTipAnywhereArea" onClick="onClickClearTipAnywhereArea">
                <ThreePartBitmap profile="edc_optionSliderBg" name="ignore">
                    <ThreePartBitmap profile="edc_outlineBg"/>
                </ThreePartBitmap>
            </OptionSlider>
            <Button profile="edc_buttonClose" id="buttonConfirmClearTipAnywhere" onClick="onClickConfirmClearTipAnywhere">
                <ThreePartBitmap profile="edc_buttonBg"/>
                <ThreePartBitmap profile="edc_outlineBg"/>
            </Button>

            <BinaryOption profile="edc_binaryOption" id="binaryShowTipCollisions" onClick="onClickShowTipCollisions">
                <Text profile="edc_title" name="ignore" text="$l10n_easyDevControls_showTipCollisionsTitle"/>
            </BinaryOption>
        </BoxLayout>

        <ThreePartBitmap profile="edc_infoBoxBg">
            <Bitmap profile="edc_infoBoxIconBox">
                <Bitmap profile="edc_infoBoxIcon" id="infoBoxIcon"/>
            </Bitmap>
            <Text profile="edc_infoBoxText" id="infoBoxText"/>
        </ThreePartBitmap>
    </GuiElement>
</GUI>
