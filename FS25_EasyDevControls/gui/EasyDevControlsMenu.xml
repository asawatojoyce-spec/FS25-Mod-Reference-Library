<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <Bitmap profile="fs25_fullScreenBackground" id="background" imageColor="0.01681 0.01764 0.016 0.99"/>
    <Paging profile="uiInGameMenuPaging" onPageChange="onPageChange" onPageUpdate="onPageUpdate" id="pagingElement">
        <FrameReference ref="easyDevControlsGeneral" name="easyDevControlsGeneral" id="pageGeneral"/>
        <FrameReference ref="easyDevControlsPlayer" name="easyDevControlsPlayer" id="pagePlayer"/>
        <FrameReference ref="easyDevControlsObjects" name="easyDevControlsObjects" id="pageObjects"/>
