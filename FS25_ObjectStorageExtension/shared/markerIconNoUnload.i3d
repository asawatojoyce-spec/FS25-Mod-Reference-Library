<?xml version="1.0" encoding="iso-8859-1"?>

<i3D name="markerIconNoUnload" version="1.6" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://i3d.giants.ch/schema/i3d-1.6.xsd">

  <Files>
    <File fileId="2" filename="$data/shaders/glowShader.xml" />
    <File fileId="1" filename="markerIcons_diffuse.dds" />
  </Files>

  <Materials>
    <Material name="markerIcons_mat" materialId="1" specularColor="0 0 0" alphaBlending="true" customShaderId="2" customShaderVariation="additive_billboard_pulsating">
      <CustomParameter name="lightControl" value="0.25"/>
      <Emissivemap fileId="1"/>
    </Material>
  </Materials>


  <Shapes externalShapesFile="markerIconNoUnload.i3d.shapes">
  </Shapes>

  <Scene>
    <TransformGroup name="markerIconNoUnload" nodeId="1">
      <Shape name="iconNoUnload" translation="0 1 0" shapeId="1" castsShadows="true" receiveShadows="true" materialIds="1" clipDistance="300" nodeId="2"/>
      <Light name="pointLight" translation="0 1 0" type="point" color="0.9 0 0" emitDiffuse="true" emitSpecular="true" range="1.5" clipDistance="100" nodeId="3"/>
    </TransformGroup>
  </Scene>

  <UserAttributes>
  </UserAttributes>
</i3D>
