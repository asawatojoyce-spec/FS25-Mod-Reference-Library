<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="objectStorage" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_storeItem_baleStorage350</name>
        <functions>
            <function>$l10n_function_objectStorage</function>
        </functions>
        <image>store/store_baleStorage350.png</image>
        <price>2200</price>
        <dailyUpkeep>0</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>storages</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>silos</tab>
        </brush>
        <audioMemoryUsage>0</audioMemoryUsage>
        <vertexBufferMemoryUsage>3072</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>2048</indexBufferMemoryUsage>
        <textureMemoryUsage>131072</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>i3d/storageBale350.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>

        <sounds>
            <place template="medImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height" groundType="dirt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
    </indoorAreas>

    <triggerMarkers>
        <triggerMarker node="warningStripes" />
        <triggerMarker node="playerTriggerMarker" filename="$data/shared/assets/marker/markerIconLoad.i3d"   adjustToGround="true" />
        <triggerMarker node="objectTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="LOADING" />
    </hotspots>

    <infoTrigger triggerNode="infoTrigger"/>

    <objectStorage capacity="350" supportsBales="true" supportsPallets="false" maxLength="8.5" maxWidth="6" maxHeight="3.5">
        <playerTrigger node="playerTrigger" />
        <objectTrigger node="objectTrigger" />
        <spawnAreas>
            <spawnArea startNode="spawnArea1Start" endNode="spawnArea1End"/>
        </spawnAreas>
        <storageAreas>
            <storageArea startNode="storageArea1Start" endNode="storageArea1End"/>
        </storageAreas>
    </objectStorage>

    <pointOfInterest>
        <point triggerNode="objectTrigger" text="$l10n_poi_objectStorageUnload" showOwner="true"  showEveryone="false"/>
        <point triggerNode="playerTrigger" text="$l10n_poi_objectStorageLoad"   showOwner="true"  showEveryone="false" />
    </pointOfInterest>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
        </updateAreas>
    </ai>

    <i3dMappings>
        <i3dMapping id="testArea1Start" node="0>0" />
        <i3dMapping id="testArea1End" node="0>0|0" />
        <i3dMapping id="clearArea1Start" node="0>1" />
        <i3dMapping id="clearArea1Width" node="0>1|0" />
        <i3dMapping id="clearArea1Height" node="0>1|1" />
        <i3dMapping id="levelArea1Start" node="0>2" />
        <i3dMapping id="levelArea1Width" node="0>2|0" />
        <i3dMapping id="levelArea1Height" node="0>2|1" />
        <i3dMapping id="tipOcclusionUpdateArea1Start" node="0>3" />
        <i3dMapping id="tipOcclusionUpdateArea1End" node="0>3|0" />
        <i3dMapping id="spawnArea1Start" node="0>4|0|0" />
        <i3dMapping id="spawnArea1End" node="0>4|0|0|0" />
        <i3dMapping id="storageArea1Start" node="0>4|0|1" />
        <i3dMapping id="storageArea1End" node="0>4|0|1|0" />
        <i3dMapping id="objectTrigger" node="0>4|1" />
        <i3dMapping id="objectTriggerMarker" node="0>4|1|0" />
        <i3dMapping id="warningStripes" node="0>4|1|1" />
        <i3dMapping id="playerTrigger" node="0>4|2" />
        <i3dMapping id="playerTriggerMarker" node="0>4|2|0" />
        <i3dMapping id="infoTrigger" node="0>4|3" />
    </i3dMappings>
</placeable>
